{
  "name": "pi-loop",
  "version": "0.1.0",
  "description": "Autonomous supervisor-loop extension for Pi.",
  "type": "module",
  "main": "index.ts",
  "files": [
    "index.ts",
    "src",
    "docs",
    "README.md"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "loop",
    "supervisor"
  ],
  "scripts": {
    "build": "echo 'No build step: Pi loads TypeScript extensions via jiti.'",
    "check": "tsc --noEmit",
    "test": "node --test tests/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.3",
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@types/node": "26.1.0",
    "typebox": "1.3.4",
    "typescript": "6.0.3"
  },
  "license": "MIT"
}
